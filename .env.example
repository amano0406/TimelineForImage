# Optional. Host CLI is disabled by default. Use only for tests/dev escape hatches.
TIMELINE_FOR_IMAGE_ALLOW_HOST_CLI=

# Optional Docker bind mount sources.
# Windows PowerShell front door sets these automatically.
# WSL/Linux defaults:
TIMELINE_FOR_IMAGE_C_DRIVE_MOUNT=/mnt/c
TIMELINE_FOR_IMAGE_OUTPUT_MOUNT=/mnt/c/Users/amano/image
