{
  "schemaVersion": 1,
  "productId": "image",
  "displayName": "TimelineForImage",
  "productKind": "media-image",
  "description": "Converts local image files into image records and timeline items.",
  "commands": {
    "start": {
      "type": "powershell",
      "path": "start.ps1"
    },
    "stop": {
      "type": "powershell",
      "path": "stop.ps1"
    },
    "cli": {
      "type": "powershell",
      "path": "cli.ps1"
    }
  },
  "settings": {
    "file": "settings.json",
    "exampleFile": "settings.example.json",
    "supportsBasicDefaults": true,
    "supportsProductOverrides": true
  },
  "capabilities": {
    "fileList": true,
    "itemList": true,
    "itemRefresh": true,
    "itemDownload": true,
    "itemRemove": true,
    "modelList": true,
    "verbalization": false
  },
  "data": {
    "sourcePathsFromSettings": [
      "inputRoots[]",
      "inputRoots[].path",
      "inputDirectories[].path"
    ],
    "generatedPathsFromSettings": [
      "outputRoot",
      "outputRoot.path",
      "outputRoots[].path",
      "masterRoot.path"
    ],
    "deleteSourceData": false
  },
  "uninstall": {
    "deleteAppDirectory": true,
    "backupSettingsByDefault": true,
    "deleteGeneratedDataOptional": true,
    "deleteGeneratedDataByDefault": false,
    "deleteSourceData": false
  },
  "runtime": {
    "usesDocker": true,
    "dockerManagedByTimeline": false
  }
}
