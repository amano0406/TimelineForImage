{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amano0406/TimelineForImage/schemas/settings.schema.json",
  "title": "TimelineForImage settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "inputRoots", "outputRoot"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "inputRoots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      }
    },
    "outputRoot": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  }
}
