{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amano0406/TimelineForImage/schemas/settings.schema.json",
  "title": "TimelineForImage settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runtime", "inputRoots", "outputRoot", "computeMode"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instanceName", "apiPort"],
      "properties": {
        "instanceName": {
          "type": "string"
        },
        "apiPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "inputRoots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "\\S"
      }
    },
    "outputRoot": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "huggingfaceToken": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "computeMode": {
      "type": "string",
      "enum": ["auto", "cpu", "gpu"]
    }
  }
}
